#include <cstddef>
#include <utility>

template<typename ValueType>
class MyList {
    struct Node {
        ValueType value;
        Node* prev;
        Node* next;
        Node(const ValueType& v, Node* p=nullptr, Node* n=nullptr)
            : value(v), prev(p), next(n) {}
    };

    Node* head_;
    Node* tail_;
    int   size_;

    void init_empty() {
        head_ = tail_ = nullptr;
        size_ = 0;
    }

    void append_node(Node* node) {
        if (!head_) {
            head_ = tail_ = node;
            node->prev = node->next = nullptr;
        } else {
            tail_->next = node;
            node->prev = tail_;
            node->next = nullptr;
            tail_ = node;
        }
        ++size_;
    }

    Node* nth_node(int index) const {
        if (index < 0 || index >= size_) return nullptr;
        if (index <= size_/2) {
            Node* cur = head_;
            for (int i=0;i<index;++i) cur = cur->next;
            return cur;
        } else {
            Node* cur = tail_;
            for (int i=size_-1;i>index;--i) cur = cur->prev;
            return cur;
        }
    }

public:
    MyList() { init_empty(); }

    MyList(MyList &&obj) noexcept : head_(obj.head_), tail_(obj.tail_), size_(obj.size_) {
        obj.init_empty();
    }

    MyList(const MyList &obj) : head_(nullptr), tail_(nullptr), size_(0) {
        for (Node* cur = obj.head_; cur; cur = cur->next) {
            append_node(new Node(cur->value));
        }
    }

    ~MyList() { clear(); }

    MyList& operator=(const MyList& other) {
        if (this == &other) return *this;
        clear();
        for (Node* cur = other.head_; cur; cur = cur->next) {
            append_node(new Node(cur->value));
        }
        return *this;
    }

    MyList& operator=(MyList&& other) noexcept {
        if (this == &other) return *this;
        clear();
        head_ = other.head_;
        tail_ = other.tail_;
        size_ = other.size_;
        other.init_empty();
        return *this;
    }

    void push_back(const ValueType &value) {
        append_node(new Node(value));
    }

    void pop_back() {
        if (!tail_) return;
        Node* t = tail_;
        tail_ = tail_->prev;
        if (tail_) tail_->next = nullptr; else head_ = nullptr;
        delete t;
        --size_;
    }

    void push_front(const ValueType &value) {
        Node* node = new Node(value);
        if (!head_) {
            head_ = tail_ = node;
        } else {
            node->next = head_;
            head_->prev = node;
            head_ = node;
        }
        ++size_;
    }

    void pop_front() {
        if (!head_) return;
        Node* h = head_;
        head_ = head_->next;
        if (head_) head_->prev = nullptr; else tail_ = nullptr;
        delete h;
        --size_;
    }

    ValueType &front() const {
        // Note: method is const, but returns non-const ref per spec
        return const_cast<ValueType&>(head_->value);
    }

    ValueType &back() const {
        return const_cast<ValueType&>(tail_->value);
    }

    void insert(int index,const ValueType &value) {
        if (index <= 0) { push_front(value); return; }
        if (index >= size_) { push_back(value); return; }
        Node* pos = nth_node(index);
        Node* node = new Node(value);
        node->next = pos;
        node->prev = pos->prev;
        if (pos->prev) pos->prev->next = node; else head_ = node;
        pos->prev = node;
        ++size_;
    }

    void erase(int index) {
        if (index < 0 || index >= size_) return;
        if (index == 0) { pop_front(); return; }
        if (index == size_-1) { pop_back(); return; }
        Node* pos = nth_node(index);
        if (!pos) return;
        pos->prev->next = pos->next;
        pos->next->prev = pos->prev;
        delete pos;
        --size_;
    }

    int size() const { return size_; }

    bool empty() const { return size_ == 0; }

    void clear() {
        Node* cur = head_;
        while (cur) {
            Node* nxt = cur->next;
            delete cur;
            cur = nxt;
        }
        init_empty();
    }

    void link(const MyList &obj) {
        for (Node* cur = obj.head_; cur; cur = cur->next) {
            append_node(new Node(cur->value));
        }
    }

    MyList cut(int index) {
        MyList right;
        if (index <= 0) {
            // move all to right
            right.head_ = head_;
            right.tail_ = tail_;
            right.size_ = size_;
            init_empty();
            return right;
        }
        if (index >= size_) {
            return right; // empty
        }
        Node* cut_pos = nth_node(index);
        Node* left_tail = cut_pos->prev;
        // Detach right part
        right.head_ = cut_pos;
        right.tail_ = tail_;
        // compute sizes
        right.size_ = size_ - index;
        size_ = index;

        // fix links
        if (left_tail) left_tail->next = nullptr;
        cut_pos->prev = nullptr;
        tail_ = left_tail;
        return right;
    }
};

#include <vector>
#include <algorithm>

template<typename ValueType>
class MyList {
    std::vector<ValueType> v;
public:
    MyList() = default;
    MyList(MyList &&obj) noexcept : v(std::move(obj.v)) {}
    MyList(const MyList &obj) : v(obj.v) {}
    ~MyList() = default;

    MyList& operator=(const MyList& other) { v = other.v; return *this; }
    MyList& operator=(MyList&& other) noexcept { v = std::move(other.v); return *this; }

    void push_back(const ValueType &value) { v.push_back(value); }
    void pop_back() { if (!v.empty()) v.pop_back(); }
    void push_front(const ValueType &value) { v.insert(v.begin(), value); }
    void pop_front() { if (!v.empty()) v.erase(v.begin()); }

    ValueType &front() const { return const_cast<ValueType&>(v.front()); }
    ValueType &back() const { return const_cast<ValueType&>(v.back()); }

    void insert(int index,const ValueType &value) {
        if (index <= 0) v.insert(v.begin(), value);
        else if (index >= (int)v.size()) v.push_back(value);
        else v.insert(v.begin()+index, value);
    }
    void erase(int index) {
        if (index < 0 || index >= (int)v.size()) return;
        v.erase(v.begin()+index);
    }

    int size() const { return static_cast<int>(v.size()); }
    bool empty() const { return v.empty(); }
    void clear() { v.clear(); }

    void link(const MyList &obj) {
        v.insert(v.end(), obj.v.begin(), obj.v.end());
    }
    MyList cut(int index) {
        MyList right;
        if (index <= 0) { right.v = std::move(v); v.clear(); return right; }
        if (index >= (int)v.size()) return right;
        right.v.assign(v.begin()+index, v.end());
        v.resize(index);
        return right;
    }
};
